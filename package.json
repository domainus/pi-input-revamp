{
  "name": "@nerisma/pi-input-revamp",
  "version": "1.0.0",
  "description": "Éditeur d'input revisité pour pi : cadre arrondi complet, prompt π coloré, et barre de métriques de session (modèle, coût, tokens, contexte).",
  "keywords": [
    "pi-package",
    "pi-extension",
    "editor",
    "tui"
  ],
  "license": "MIT",
  "author": "Sébastien SERVOUZE <sebastien.servouze@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nerisma/pi-input-revamp.git"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
